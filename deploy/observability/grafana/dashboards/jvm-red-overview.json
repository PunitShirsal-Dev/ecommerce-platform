{
  "title": "JVM / RED overview",
  "schemaVersion": 39,
  "version": 1,
  "panels": [
    {
      "type": "stat",
      "title": "Request rate (example query)",
      "gridPos": { "h": 4, "w": 8, "x": 0, "y": 0 },
      "targets": [{ "expr": "sum(rate(http_server_requests_seconds_count[5m]))" }]
    },
    {
      "type": "stat",
      "title": "Error ratio",
      "gridPos": { "h": 4, "w": 8, "x": 8, "y": 0 },
      "targets": [{ "expr": "sum(rate(http_server_requests_seconds_count{status=~\"5..\"}[5m])) / sum(rate(http_server_requests_seconds_count[5m]))" }]
    },
    {
      "type": "stat",
      "title": "p95 latency",
      "gridPos": { "h": 4, "w": 8, "x": 16, "y": 0 },
      "targets": [{ "expr": "histogram_quantile(0.95, sum(rate(http_server_requests_seconds_bucket[5m])) by (le))" }]
    }
  ]
}
